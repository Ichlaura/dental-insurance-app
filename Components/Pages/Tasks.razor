@page "/tasks"
@rendermode InteractiveServer

<PageTitle>Dental Insurance App</PageTitle>

<h1>Dental Insurance App</h1>

<div style="margin-bottom:20px;">
    <input @bind="newPatient" placeholder="Patient Name" />
    <input @bind="newInsurance" placeholder="Insurance" />
    <input @bind="newGroup" placeholder="Group #" />
    <button @onclick="AddRecord">Add</button>
</div>

<div style="margin-bottom:20px;">
    <button @onclick='() => SetFilter("All")'>All</button>
    <button @onclick='() => SetFilter("Pending")'>Pending</button>
    <button @onclick='() => SetFilter("Verified")'>Verified</button>
</div>

<ul>
    @foreach (var item in FilteredRecords)
    {
        <li>
            <input type="checkbox" checked="@item.Verified" @onchange="() => Toggle(item)" />
            <b>@item.Patient</b> - @item.Insurance (Group: @item.Group)

            @if (item.Verified)
            {
                <span style="color:green;">✔ Verified</span>
            }
            else
            {
                <span style="color:orange;">Pending</span>
            }

            <button @onclick="() => Delete(item)">Delete</button>
        </li>
    }
</ul>

@code {
    string newPatient = "";
    string newInsurance = "";
    string newGroup = "";
    string currentFilter = "All";

    List<Record> records = new();

    IEnumerable<Record> FilteredRecords =>
        currentFilter switch
        {
            "Pending" => records.Where(x => !x.Verified),
            "Verified" => records.Where(x => x.Verified),
            _ => records
        };

    void AddRecord()
    {
        if (!string.IsNullOrWhiteSpace(newPatient))
        {
            records.Add(new Record
            {
                Patient = newPatient,
                Insurance = newInsurance,
                Group = newGroup
            });

            newPatient = "";
            newInsurance = "";
            newGroup = "";
        }
    }

    void Delete(Record r)
    {
        records.Remove(r);
    }

    void Toggle(Record r)
    {
        r.Verified = !r.Verified;
    }

    void SetFilter(string f)
    {
        currentFilter = f;
    }

    class Record
    {
        public string Patient { get; set; } = "";
        public string Insurance { get; set; } = "";
        public string Group { get; set; } = "";
        public bool Verified { get; set; }
    }
}