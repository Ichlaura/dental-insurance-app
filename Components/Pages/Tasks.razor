@page "/tasks"
@rendermode InteractiveServer

<PageTitle>Dental Insurance Verification</PageTitle>

<div class="insurance-page">
    <section class="hero shadow-sm">
        <div class="hero-content">
            <p class="eyebrow">DENTAL INSURANCE VERIFICATION</p>
            <h1>Professional insurance record management for dental offices</h1>
            <p class="hero-text">
                Track patient insurance details, verification status, and office workflow in one clean dashboard.
            </p>
        </div>

        <div class="hero-summary">
            <div class="summary-card">
                <span class="summary-number">@records.Count</span>
                <span class="summary-label">Total Records</span>
            </div>
            <div class="summary-card">
                <span class="summary-number">@records.Count(r => r.Verified)</span>
                <span class="summary-label">Verified</span>
            </div>
            <div class="summary-card">
                <span class="summary-number">@records.Count(r => !r.Verified)</span>
                <span class="summary-label">Pending</span>
            </div>
        </div>
    </section>

    <section class="top-grid">
        <div class="form-card shadow-sm">
            <div class="section-head">
                <div>
                    <h2>@(isEditing ? "Edit Insurance Record" : "Add Insurance Record")</h2>
                    <p>@(isEditing ? "Update the selected patient insurance record." : "Create a new patient insurance verification record.")</p>
                </div>
                <span class="mini-badge">Blazor App</span>
            </div>

            <div class="form-grid">
                <div>
                    <label>Patient Name</label>
                    <input class="form-control @(showValidation && string.IsNullOrWhiteSpace(newPatient) ? "input-error" : "")"
                           @bind="newPatient"
                           placeholder="Maria Lopez" />
                </div>

                <div>
                    <label>Insurance Provider</label>
                    <input class="form-control @(showValidation && string.IsNullOrWhiteSpace(newInsurance) ? "input-error" : "")"
                           @bind="newInsurance"
                           placeholder="Aetna" />
                </div>

                <div>
                    <label>Group Number</label>
                    <input class="form-control @(showValidation && string.IsNullOrWhiteSpace(newGroup) ? "input-error" : "")"
                           @bind="newGroup"
                           placeholder="AET-2049" />
                </div>
            </div>

            @if (showValidation && HasEmptyFields())
            {
                <div class="validation-box">
                    Please complete Patient Name, Insurance Provider, and Group Number.
                </div>
            }

            <div class="button-row">
                @if (isEditing)
                {
                    <button class="btn btn-primary btn-lg px-4" @onclick="SaveEdit">Save Changes</button>
                    <button class="btn btn-outline-secondary btn-lg px-4" @onclick="CancelEdit">Cancel</button>
                }
                else
                {
                    <button class="btn btn-primary btn-lg px-4" @onclick="AddRecord">Add Record</button>
                }
            </div>
        </div>

        <div class="side-card shadow-sm">
            <div class="section-head">
                <div>
                    <h2>Workflow Overview</h2>
                    <p>A simple process for dental insurance verification.</p>
                </div>
            </div>

            <div class="workflow-list">
                <div class="workflow-item">
                    <span class="step-number">1</span>
                    <div>
                        <h5>Create Record</h5>
                        <p>Add patient, insurance, and group details.</p>
                    </div>
                </div>

                <div class="workflow-item">
                    <span class="step-number">2</span>
                    <div>
                        <h5>Review Status</h5>
                        <p>Track whether the record is pending or verified.</p>
                    </div>
                </div>

                <div class="workflow-item">
                    <span class="step-number">3</span>
                    <div>
                        <h5>Update Anytime</h5>
                        <p>Edit or delete records as office needs change.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="records-card shadow-sm">
        <div class="records-header">
            <div>
                <h2>Insurance Records Dashboard</h2>
                <p>Monitor all patient insurance records in a clean, organized layout.</p>
            </div>

            <div class="filter-group">
                <button class="btn @(currentFilter == "All" ? "btn-dark" : "btn-outline-dark")"
                        @onclick='() => SetFilter("All")'>All</button>

                <button class="btn @(currentFilter == "Pending" ? "btn-warning" : "btn-outline-warning")"
                        @onclick='() => SetFilter("Pending")'>Pending</button>

                <button class="btn @(currentFilter == "Verified" ? "btn-success" : "btn-outline-success")"
                        @onclick='() => SetFilter("Verified")'>Verified</button>
            </div>
        </div>

        @if (FilteredRecords.Any())
        {
            <div class="records-table-wrap">
                <table class="records-table">
                    <thead>
                        <tr>
                            <th>Status</th>
                            <th>Patient</th>
                            <th>Insurance</th>
                            <th>Group Number</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in FilteredRecords)
                        {
                            <tr class="@(item.Verified ? "row-verified" : "")">
                                <td>
                                    <button class="status-toggle @(item.Verified ? "verified" : "pending")"
                                            @onclick="() => Toggle(item)">
                                        @(item.Verified ? "Verified" : "Pending")
                                    </button>
                                </td>
                                <td>
                                    <div class="patient-cell">
                                        <div class="patient-avatar">
                                            @item.Patient.Substring(0, 1).ToUpper()
                                        </div>
                                        <div>
                                            <strong>@item.Patient</strong>
                                            <div class="cell-subtext">Patient record</div>
                                        </div>
                                    </div>
                                </td>
                                <td>@item.Insurance</td>
                                <td>@item.Group</td>
                                <td>
                                    <div class="action-buttons">
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => StartEdit(item)">Edit</button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => Delete(item)">Delete</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <h4>No records found</h4>
                <p>Add a new insurance record to get started.</p>
            </div>
        }
    </section>
</div>

<style>
    .insurance-page {
        min-height: 100vh;
        padding: 2rem;
        background:
            radial-gradient(circle at top left, rgba(59,130,246,0.12), transparent 26%),
            linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%);
    }

    .hero {
        border-radius: 30px;
        padding: 2rem;
        margin-bottom: 1.75rem;
        background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 60%, #2563eb 100%);
        color: white;
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 1.5rem;
        align-items: center;
    }

    .eyebrow {
        font-size: 0.8rem;
        letter-spacing: 0.14rem;
        font-weight: 700;
        opacity: 0.82;
        margin-bottom: 0.7rem;
    }

    .hero h1 {
        font-size: 2.35rem;
        line-height: 1.12;
        font-weight: 800;
        margin-bottom: 0.85rem;
        max-width: 720px;
    }

    .hero-text {
        max-width: 650px;
        font-size: 1rem;
        opacity: 0.95;
        margin: 0;
    }

    .hero-summary {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .summary-card {
        min-width: 135px;
        border-radius: 22px;
        padding: 1rem 1.15rem;
        background: rgba(255,255,255,0.14);
        border: 1px solid rgba(255,255,255,0.18);
        backdrop-filter: blur(8px);
        display: flex;
        flex-direction: column;
    }

    .summary-number {
        font-size: 1.95rem;
        font-weight: 800;
        line-height: 1.05;
    }

    .summary-label {
        font-size: 0.92rem;
        margin-top: 0.3rem;
        opacity: 0.92;
    }

    .top-grid {
        display: grid;
        grid-template-columns: 1.8fr 1fr;
        gap: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .form-card,
    .side-card,
    .records-card {
        background: white;
        border-radius: 26px;
        padding: 1.6rem;
    }

    .section-head {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: flex-start;
        margin-bottom: 1.1rem;
    }

    .section-head h2,
    .records-header h2 {
        margin-bottom: 0.25rem;
        font-size: 1.4rem;
        font-weight: 800;
        color: #0f172a;
    }

    .section-head p,
    .records-header p {
        margin: 0;
        color: #64748b;
    }

    .mini-badge {
        background: #dbeafe;
        color: #1d4ed8;
        padding: 0.45rem 0.8rem;
        border-radius: 999px;
        font-size: 0.82rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
    }

    .form-grid label {
        display: block;
        font-weight: 700;
        font-size: 0.92rem;
        color: #334155;
        margin-bottom: 0.45rem;
    }

    .form-control {
        height: 50px;
        border-radius: 14px;
        border: 1px solid #cbd5e1;
        box-shadow: none;
    }

    .form-control:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 0.2rem rgba(37,99,235,0.12);
    }

    .input-error {
        border: 1px solid #f59e0b !important;
        background: #fffbeb;
    }

    .validation-box {
        margin-top: 1rem;
        padding: 0.85rem 1rem;
        border-radius: 14px;
        background: #fff7ed;
        color: #9a3412;
        border: 1px solid #fdba74;
        font-size: 0.94rem;
        font-weight: 600;
    }

    .button-row {
        margin-top: 1.2rem;
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .workflow-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .workflow-item {
        display: flex;
        align-items: flex-start;
        gap: 0.85rem;
        padding: 1rem;
        border-radius: 18px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
    }

    .workflow-item h5 {
        margin: 0 0 0.2rem 0;
        font-size: 1rem;
        font-weight: 700;
        color: #0f172a;
    }

    .workflow-item p {
        margin: 0;
        color: #64748b;
        font-size: 0.92rem;
    }

    .step-number {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: #2563eb;
        color: white;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        flex-shrink: 0;
        margin-top: 0.1rem;
    }

    .records-header {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: flex-start;
        margin-bottom: 1.25rem;
        flex-wrap: wrap;
    }

    .filter-group {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .records-table-wrap {
        overflow-x: auto;
        border: 1px solid #e2e8f0;
        border-radius: 20px;
    }

    .records-table {
        width: 100%;
        border-collapse: collapse;
        background: white;
    }

    .records-table thead th {
        text-align: left;
        padding: 1rem 1rem;
        background: #f8fafc;
        color: #334155;
        font-size: 0.92rem;
        font-weight: 800;
        border-bottom: 1px solid #e2e8f0;
    }

    .records-table tbody td {
        padding: 1rem;
        border-bottom: 1px solid #eef2f7;
        vertical-align: middle;
        color: #0f172a;
    }

    .records-table tbody tr:last-child td {
        border-bottom: none;
    }

    .row-verified {
        background: #f0fdf4;
    }

    .patient-cell {
        display: flex;
        align-items: center;
        gap: 0.85rem;
    }

    .patient-avatar {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background: linear-gradient(135deg, #2563eb, #60a5fa);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .cell-subtext {
        color: #64748b;
        font-size: 0.85rem;
        margin-top: 0.15rem;
    }

    .status-toggle {
        border: none;
        border-radius: 999px;
        padding: 0.5rem 0.9rem;
        font-size: 0.87rem;
        font-weight: 700;
    }

    .status-toggle.verified {
        background: #dcfce7;
        color: #166534;
    }

    .status-toggle.pending {
        background: #fef3c7;
        color: #92400e;
    }

    .action-buttons {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .empty-state {
        text-align: center;
        padding: 3rem 1rem;
        border: 2px dashed #cbd5e1;
        border-radius: 20px;
        background: #f8fafc;
        color: #64748b;
    }

    @@media (max-width: 1100px) {
        .hero,
        .top-grid {
            grid-template-columns: 1fr;
        }

        .hero-summary {
            justify-content: flex-start;
        }
    }

    @@media (max-width: 768px) {
        .insurance-page {
            padding: 1rem;
        }

        .hero,
        .form-card,
        .side-card,
        .records-card {
            padding: 1.2rem;
        }

        .hero h1 {
            font-size: 1.75rem;
        }

        .form-grid {
            grid-template-columns: 1fr;
        }

        .records-table thead {
            display: none;
        }

        .records-table,
        .records-table tbody,
        .records-table tr,
        .records-table td {
            display: block;
            width: 100%;
        }

        .records-table tr {
            padding: 1rem;
            border-bottom: 1px solid #e2e8f0;
        }

        .records-table td {
            padding: 0.45rem 0;
            border: none;
        }
    }
</style>

@code {
    string newPatient = "";
    string newInsurance = "";
    string newGroup = "";
    string currentFilter = "All";
    bool showValidation = false;
    bool isEditing = false;
    Record? editingRecord = null;

    List<Record> records = new()
    {
        new Record { Patient = "Maria Lopez", Insurance = "Aetna", Group = "AET-2049", Verified = true },
        new Record { Patient = "John Smith", Insurance = "Cigna", Group = "CGN-3318", Verified = false },
        new Record { Patient = "Ana Torres", Insurance = "Delta Dental", Group = "DDL-7782", Verified = false }
    };

    IEnumerable<Record> FilteredRecords =>
        currentFilter switch
        {
            "Pending" => records.Where(x => !x.Verified),
            "Verified" => records.Where(x => x.Verified),
            _ => records
        };

    bool HasEmptyFields()
    {
        return string.IsNullOrWhiteSpace(newPatient)
            || string.IsNullOrWhiteSpace(newInsurance)
            || string.IsNullOrWhiteSpace(newGroup);
    }

    void AddRecord()
    {
        showValidation = true;

        if (HasEmptyFields())
            return;

        records.Insert(0, new Record
        {
            Patient = newPatient.Trim(),
            Insurance = newInsurance.Trim(),
            Group = newGroup.Trim(),
            Verified = false
        });

        ClearForm();
    }

    void StartEdit(Record r)
    {
        isEditing = true;
        editingRecord = r;
        newPatient = r.Patient;
        newInsurance = r.Insurance;
        newGroup = r.Group;
        showValidation = false;
    }

    void SaveEdit()
    {
        showValidation = true;

        if (editingRecord is null || HasEmptyFields())
            return;

        editingRecord.Patient = newPatient.Trim();
        editingRecord.Insurance = newInsurance.Trim();
        editingRecord.Group = newGroup.Trim();

        ClearForm();
    }

    void CancelEdit()
    {
        ClearForm();
    }

    void Delete(Record r)
    {
        if (editingRecord == r)
        {
            ClearForm();
        }

        records.Remove(r);
    }

    void Toggle(Record r)
    {
        r.Verified = !r.Verified;
    }

    void SetFilter(string f)
    {
        currentFilter = f;
    }

    void ClearForm()
    {
        newPatient = "";
        newInsurance = "";
        newGroup = "";
        showValidation = false;
        isEditing = false;
        editingRecord = null;
    }

    class Record
    {
        public string Patient { get; set; } = "";
        public string Insurance { get; set; } = "";
        public string Group { get; set; } = "";
        public bool Verified { get; set; }
    }
}